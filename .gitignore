# =============================================================================
# Hyper-V / virtualization artifacts
# =============================================================================
# Large binary VM state. Regenerated by the provisioning scripts, not a source
# of truth, and not useful outside this one host.

/ISO/
/Exports/
/VMs/
/seeds/

# Belt and braces: any hypervisor binary files anywhere in the tree
*.vhdx
*.avhdx
*.vhd
*.vmcx
*.vmrs
*.vmgs
*.iso
*.img

# =============================================================================
# Secrets and credentials
# =============================================================================
# Nothing should live in this repo, but these patterns catch accidents.

*.key
*.pem
*.ppk
*.p12
*.pfx
*.crt
*.cer

id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub
authorized_keys
known_hosts

# Lab-specific SSH key names we've used
controlplane01
controlplane01.pub

# Tailscale auth state / preauth keys
*.tailnet.key
*.tsauthkey
tailscale_*.state

# Env files that might hold secrets
.env
.env.*
!.env.example

# =============================================================================
# Backup and temporary files
# =============================================================================
*.bak
*.backup
*.orig
*.tmp
*.swp
*.swo
*~
.#*
#*#

# Logs
*.log
/logs/
/tmp/

# =============================================================================
# Local overrides
# =============================================================================
# Convention: suffix any personal/private overrides with .local so they never
# get committed even if someone forgets to add a specific rule here.
*.local.ps1
*.local.sh
*.local.yaml
*.local.yml
*.local.json
00-config.local.ps1

# =============================================================================
# OS / editor droppings
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

.idea/
.vs/
*.suo
*.user
*.userprefs

# VS Code: keep shared workspace bits, ignore per-user noise
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# =============================================================================
# Tooling working directories
# =============================================================================
# Structurizr's generated/cached files when the renderer is pointed at the
# architecture directory. workspace.dsl is the source of truth; everything
# else here is generated and shouldn't be committed.
architecture/.structurizr/
architecture/workspace.json
architecture/*.png
architecture/*.svg
# structurizr-site-generatr output
architecture/build/

# Python virtualenvs if any scripts grow that direction later
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# Node if any tooling grows that direction
node_modules/
