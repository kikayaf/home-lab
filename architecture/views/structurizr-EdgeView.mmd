        style 15 fill:#6a1b9a,stroke:#4a126b,color:#ffffff
      end

      subgraph group6 ["Security layer (cross-cutting)"]
        style group6 fill:#ffebee,stroke:#c62828,color:#b71c1c,stroke-width:2px

